# ─── LLM Providers (multi-model, like Computer) ──────────────
ANTHROPIC_API_KEY=sk-ant-...           # Claude 3.5 Sonnet — default agent model
OPENAI_API_KEY=sk-...                  # GPT-4o, GPT-4o-mini, text-embedding-3-small
GOOGLE_AI_API_KEY=AIza...              # Gemini 1.5 Pro/Flash

# Model routing defaults
DEFAULT_AGENT_MODEL=claude-3-5-sonnet-20241022
DEFAULT_FAST_MODEL=gpt-4o-mini
DEFAULT_SUBAGENT_MODEL=claude-3-5-sonnet-20241022
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# ─── Supabase (Memory + pgvector + Auth + Storage) ───────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ─── Redis (BullMQ job queue + pub/sub for streaming) ─────────
REDIS_URL=redis://localhost:6379

# ─── Workspace (sandboxed FS — mirroring Computer's Linux VM) ─
WORKSPACE_BASE_PATH=/tmp/infinius-workspaces

# ─── API Server ────────────────────────────────────────────────
API_PORT=3001
API_SECRET=change-me-32-chars-min
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Web App (Next.js) ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ─── Browser Automation (Playwright) ──────────────────────────
# Local: leave blank. Cloud: set to your Browserless/Bright Data endpoint
BROWSER_WS_ENDPOINT=

# ─── Search Tools ──────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=BSA...            # Web search
TAVILY_API_KEY=tvly-...                # Research-grade web search
SERPER_API_KEY=...                     # Google SERP fallback

# ─── OAuth Connectors (Pipedream Connect) ─────────────────────
# Pipedream Connect powers the 400+ connector framework
PIPEDREAM_PROJECT_ID=proj_...
PIPEDREAM_PROJECT_ENVIRONMENT=development
PIPEDREAM_CLIENT_ID=...
PIPEDREAM_CLIENT_SECRET=...

# ─── Media Generation ──────────────────────────────────────────
REPLICATE_API_TOKEN=r8_...             # Image generation via Replicate (Flux/SD)
                                       # If not set, falls back to DALL-E 3
ELEVENLABS_API_KEY=...                 # TTS via ElevenLabs (falls back to OpenAI TTS)

# ─── PDF Generation (Chromium) ──────────────────────────────────
# Path to Chromium/Chrome binary for PDF rendering
# Railway/Docker: /usr/bin/chromium-browser (auto-installed in Dockerfile)
# Mac local dev: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROMIUM_PATH=/usr/bin/chromium-browser

# ─── Supabase Storage ───────────────────────────────────────────
# Create a private bucket called 'workspace-files' in your Supabase dashboard
# then add the RLS policies from infra/supabase/migrations/002_shared_files.sql
SUPABASE_STORAGE_BUCKET=workspace-files

# ─── File Storage ──────────────────────────────────────────────
STORAGE_PROVIDER=supabase              # supabase | s3 | local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# ─── Notifications ─────────────────────────────────────────────
NOTIFICATION_PROVIDER=internal         # internal | pusher | ably

# ─── Scheduler ─────────────────────────────────────────────────
CRON_SECRET=change-me-cron-secret
